---
import '@fontsource-variable/inter/index.css';
import '@fontsource-variable/space-grotesk/index.css';
import '../styles/global.css';
import { SITE } from '../site.config';

interface Props {
  /** Page-specific part of the <title>; the site name is appended. */
  title: string;
  /** Unique meta description for this page. */
  description: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;

// Astro.site comes from astro.config.mjs — the single canonical URL boundary.
const canonical = new URL(path, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

const navLinks = [
  ['/', 'Home'],
  ['/services/', 'Services'],
  ['/process/', 'Process'],
  ['/work/', 'Work'],
  ['/about/', 'About'],
  ['/contact/', 'Contact'],
] as const;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {SITE.name}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0d141b" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={`${title} · ${SITE.name}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>

    <header class="site-header">
      <div class="container">
        <a class="brand" href="/" aria-label={`${SITE.name} home`}>
          <svg viewBox="0 0 32 32" aria-hidden="true" fill="none">
            <rect x="3" y="5" width="26" height="22" rx="3" stroke="#53c9bc" stroke-width="2.5" />
            <line x1="3" y1="11.5" x2="29" y2="11.5" stroke="#53c9bc" stroke-width="2.5" />
            <circle cx="7.5" cy="8.25" r="1.4" fill="#53c9bc" />
            <line x1="8" y1="17" x2="19" y2="17" stroke="#e9eef3" stroke-width="2.5" stroke-linecap="round" />
            <line x1="8" y1="22" x2="15" y2="22" stroke="#e9eef3" stroke-width="2.5" stroke-linecap="round" />
          </svg>
          <span>{SITE.name}</span>
        </a>
        <nav class="site-nav" aria-label="Primary">
          {navLinks.map(([href, label]) => (
            <a href={href} aria-current={path === href ? 'page' : undefined}>{label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main id="content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div>
          <a class="brand" href="/">{SITE.name}</a>
          <p>
            {SITE.tagline}. Built and maintained
            by {SITE.owner}, serving {SITE.serviceArea}.
          </p>
        </div>
        <nav aria-label="Footer site">
          <h2>Site</h2>
          <ul>
            <li><a href="/services/">Services</a></li>
            <li><a href="/process/">Process</a></li>
            <li><a href="/work/">Work</a></li>
            <li><a href="/about/">About</a></li>
          </ul>
        </nav>
        <nav aria-label="Footer contact">
          <h2>Get in touch</h2>
          <ul>
            <li><a href="/contact/">Request a quote</a></li>
            <li><a href="/privacy/">Privacy</a></li>
          </ul>
        </nav>
        <div class="footer-legal">
          <span>© {year} {SITE.owner}</span>
          <span>{SITE.serviceArea}</span>
        </div>
      </div>
    </footer>
  </body>
</html>
