---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../site.config';
---

<BaseLayout
  title="Websites for local service businesses"
  description={`Clear, fast, mobile-first websites for local service businesses in ${SITE.serviceArea}. Fixed scope, fixed quote, and you own everything.`}
>
  <section class="hero-wrap grid-paper">
    <div class="hero container">
      <div>
        <p class="eyebrow">{SITE.serviceArea}</p>
        <h1 class="ruled">Your work is solid. <em>Your website should say so.</em></h1>
        <p class="lede">
          I build clear, fast, mobile-first websites for local service
          businesses — a fixed scope, a fixed quote, and a launch process you
          can watch happen. No retainers you didn't ask for, no jargon, no
          mystery.
        </p>
        <div class="cta-row">
          <a class="btn" href="/contact/">Request a quote</a>
          <a class="btn secondary" href="/services/">See what's included</a>
        </div>
      </div>
      <aside class="scope-card" aria-label="Project specification summary">
        <p>Project spec</p>
        <dl>
          <div><dt>Pages</dt><dd>3–5, focused</dd></div>
          <div><dt>Quote</dt><dd>Fixed, in writing</dd></div>
          <div><dt>Deposit</dt><dd>50%</dd></div>
          <div><dt>Revisions</dt><dd>2 defined rounds</dd></div>
          <div><dt>Hosting</dt><dd>Cloudflare network</dd></div>
          <div><dt>Ownership</dt><dd>100% yours</dd></div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section container" aria-labelledby="fit-heading">
    <div class="section-head">
      <p class="eyebrow">Who this is for</p>
      <h2 id="fit-heading">Built for how customers actually find you</h2>
      <p>
        Most people looking for a local service search on their phone, skim
        for thirty seconds, and contact whoever looks credible and answers
        their questions. Your site has one job: pass that thirty-second test.
      </p>
    </div>
    <div class="tile-grid">
      <div class="tile">
        <h3>Fast on any phone</h3>
        <p>
          Lightweight pages that load quickly on a job-site connection, not
          just on office wifi. No bloated page builders or plugin stacks.
        </p>
      </div>
      <div class="tile">
        <h3>Answers the real questions</h3>
        <p>
          Do you serve my area? What exactly do you do? Can I trust you? How
          do I reach you? Every page is organized around those questions.
        </p>
      </div>
      <div class="tile">
        <h3>One tap to contact you</h3>
        <p>
          Clear calls to action on every page, so an interested visitor never
          has to hunt for how to request a quote.
        </p>
      </div>
    </div>
  </section>

  <section class="section container" aria-labelledby="how-heading">
    <div class="section-head">
      <p class="eyebrow">How it works</p>
      <h2 id="how-heading">A defined process, start to finish</h2>
      <p>
        You'll know the scope, the price, and the schedule before any work
        begins — and you'll watch the site take shape on a private preview
        link.
      </p>
    </div>
    <ol class="steps">
      <li>
        <div>
          <h3>Scope and quote</h3>
          <p>
            A short conversation about your business, then a written fixed
            quote listing exactly what's included.
          </p>
        </div>
      </li>
      <li>
        <div>
          <h3>Build and preview</h3>
          <p>
            I build the site and share a private preview link so you can see
            real progress on your own phone, not mockups.
          </p>
        </div>
      </li>
      <li>
        <div>
          <h3>Launch and handoff</h3>
          <p>
            The site goes live on fast, reliable hosting — and you own the
            domain, the code, and the content. No lock-in.
          </p>
        </div>
      </li>
    </ol>
    <div class="cta-row">
      <a class="btn secondary" href="/process/">See the full process</a>
    </div>
  </section>

  <section class="section container" aria-labelledby="work-heading">
    <div class="section-head">
      <p class="eyebrow">Evidence</p>
      <h2 id="work-heading">A complete build, in the open</h2>
    </div>
    <div class="case-panel">
      <div>
        <span class="badge">Demonstration project</span>
        <h3>{SITE.demo.name} — a community running directory</h3>
        <p>
          To prove out my delivery process end to end, I built and shipped a
          real public website: research, content, design, code, automated
          checks, and deployment — with the entire history visible on GitHub.
          It's my own project, not client work, and that's the point: you can
          inspect exactly how I build before hiring me.
        </p>
        <div class="cta-row">
          <a class="btn secondary" href="/work/">Read the case study</a>
        </div>
      </div>
      <div class="browser-frame">
        <div class="frame-bar" aria-hidden="true">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span>run-psl.pages.dev</span>
        </div>
        <img
          src="/run-psl-preview.png"
          alt={`Screenshot of the ${SITE.demo.name} homepage showing its directory of local running events`}
          width="1200"
          height="900"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <div class="band dark">
    <div class="container">
      <p class="eyebrow">Founding-client rate</p>
      <h2>Early clients get a lower rate, honestly framed</h2>
      <p>
        I'm building this service deliberately, one project at a time. My
        first clients take a chance on someone newer to client work — so
        founding projects are quoted from $1,200 instead of my planned
        standard rate. Same process, same care, lower price.
      </p>
      <div class="cta-row">
        <a class="btn" href="/services/#pricing">See pricing details</a>
      </div>
    </div>
  </div>

  <section class="section container" aria-labelledby="cta-heading">
    <div class="section-head">
      <h2 id="cta-heading">Ready when you are</h2>
      <p>
        Tell me about your business and what you need. You'll get a plain
        answer about whether this package fits — and a fixed quote if it does.
      </p>
    </div>
    <div class="cta-row">
      <a class="btn" href="/contact/">Request a quote</a>
    </div>
  </section>
</BaseLayout>
